<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ocasión - Picocars</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400,600,700&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-zinc-950 text-zinc-100 min-h-screen p-6">

    <nav class="max-w-4xl mx-auto flex justify-between items-center border-b border-zinc-800 pb-4 mb-8">
        <h1 class="text-xl font-bold text-blue-500">PICOCARS <span class="text-zinc-500 text-sm font-normal">| Ocasión</span></h1>
        <a href="./index.html" class="text-sm text-zinc-400 hover:text-white">← Volver al inicio</a>
    </nav>

    <main class="max-w-4xl mx-auto">
        <!-- Buscador -->
        <div class="bg-zinc-900 p-4 rounded-xl border border-zinc-800 flex gap-4 mb-8">
            <input type="text" placeholder="Buscar marca o modelo..." class="bg-zinc-800 text-white px-4 py-2 rounded-lg w-full outline-none focus:ring-2 focus:ring-blue-500">
            <button class="bg-blue-600 text-white px-6 py-2 rounded-lg font-semibold hover:bg-blue-500 transition">Buscar</button>
        </div>

        <!-- Grid de Coches (Simulados) -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <!-- Coche 1 -->
            <div class="bg-zinc-900 rounded-xl border border-zinc-800 overflow-hidden hover:border-blue-500 transition group">
                <div class="h-48 bg-zinc-800 flex items-center justify-center text-zinc-500">
                    [Foto del Audi A3]
                </div>
                <div class="p-6">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="text-xl font-bold group-hover:text-blue-400 transition">Audi A3 S-Line</h3>
                        <span class="text-lg font-bold text-blue-500">18.500 €</span>
                    </div>
                    <p class="text-sm text-zinc-400 mb-4">2019 • 120.000 km • Diésel • Manual</p>
                    <button class="w-full bg-zinc-800 py-2 rounded-lg text-sm font-semibold hover:bg-zinc-700 transition">Ver detalles</button>
                </div>
            </div>

            <!-- Coche 2 -->
            <div class="bg-zinc-900 rounded-xl border border-zinc-800 overflow-hidden hover:border-blue-500 transition group">
                <div class="h-48 bg-zinc-800 flex items-center justify-center text-zinc-500">
                    [Foto del VW Golf]
                </div>
                <div class="p-6">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="text-xl font-bold group-hover:text-blue-400 transition">Volkswagen Golf GTI</h3>
                        <span class="text-lg font-bold text-blue-500">22.900 €</span>
                    </div>
                    <p class="text-sm text-zinc-400 mb-4">2021 • 65.000 km • Gasolina • Automático</p>
                    <button class="w-full bg-zinc-800 py-2 rounded-lg text-sm font-semibold hover:bg-zinc-700 transition">Ver detalles</button>
                </div>
            </div>

        </div>
    </main>
</body>
</html>